# Copy to .env (gitignored) and fill in. Names must match api_key_env in config.toml.

# Ollama on lambda-scalar usually ignores the key, but keep the indirection.
OLLAMA_API_KEY=ollama

# Modal-hosted inference endpoint key.
MODAL_API_KEY=

# Cloud frontier model (wiki-author profile) key.
WIKI_AUTHOR_API_KEY=
