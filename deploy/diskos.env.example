# Copy to /srv/diskos/diskos.env on homebase (NOT in git). Read by docker-compose.

# Who may sign in (comma-separated Google account emails).
DISKOS_ALLOWLIST=jack@example.com,johnm.aiken@gmail.com

# Google OAuth (create at console.cloud.google.com; authorized redirect URI must be
# https://<your-domain>/auth/callback).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session cookie signing key (generate: openssl rand -hex 32).
DISKOS_SESSION_SECRET=

# Leave DISKOS_WEB_DEV unset in production (dev bypass must be off).
# DISKOS_WEB_DEV=1
